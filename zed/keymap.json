// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && mode == full && vim_mode == normal",
    "bindings": {
      "space p f": "file_finder::Toggle",
      "space p o": "projects::OpenRecent",
      "space p s": "pane::DeploySearch",
      "space p v": "project_panel::Toggle",
      "space q": [
        "action::Sequence",
        ["pane::CloseCleanItems", "pane::CloseActiveItem"],
      ],
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "space p o": "projects::OpenRecent",
      "space p s": "pane::DeploySearch",
      "space p v": "project_panel::Toggle",
      "escape": "project_panel::Toggle",
    },
  },
  {
    "context": "ProjectSearchBar > Editor",
    "bindings": {
      "escape": "pane::CloseActiveItem",
    },
  },
  {
    "context": "ProjectSearchView > Editor",
    "bindings": {
      "escape": "pane::CloseActiveItem",
    },
  },
  {
    "context": "ProjectSearchBar || ProjectSearchView",
    "bindings": {
      "escape": "pane::CloseActiveItem",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "unbind": {
      "ctrl-q": "zed::Quit",
    },
  },
]
